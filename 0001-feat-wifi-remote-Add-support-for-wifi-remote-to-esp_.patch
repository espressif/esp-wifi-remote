+ *                Variable Declaration
+ *******************************************************/
+/* mesh IE crypto callback function */
+extern const mesh_crypto_funcs_t g_wifi_default_mesh_crypto_funcs;
+
+#define MESH_INIT_CONFIG_DEFAULT() { \
+    .crypto_funcs = &g_wifi_default_mesh_crypto_funcs, \
+}
